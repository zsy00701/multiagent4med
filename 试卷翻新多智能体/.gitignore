# ===========================================
# 医学试卷翻新多智能体系统 - Git忽略文件
# ===========================================

# 环境变量文件 (包含敏感信息)
.env
.env.local
.env.*.local

# Python 缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/
.venv

# IDE 配置文件
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# 数据文件
data/chroma_db/
data/output/*.json
data/output/*.md

# 日志文件
*.log
logs/

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/

# 临时文件
*.tmp
*.bak
.ipynb_checkpoints/

# 打包文件
dist/
build/
*.egg-info/
