# ===========================================
# 医学试卷翻新多智能体系统 - 环境变量配置示例
# ===========================================
#
# 使用说明：
# 1. 复制此文件为 .env
# 2. 填入你的实际 API Key
# 3. 根据需要调整其他配置
# ===========================================

# ============================================
# LLM API 配置
# ============================================

# 推荐配置：DeepSeek (性价比最高，中文能力强)
LLM_PROVIDER=openai
LLM_API_KEY=your_deepseek_api_key_here  # 在 https://platform.deepseek.com/ 获取
LLM_BASE_URL=https://api.deepseek.com
LLM_MODEL=deepseek-chat
LLM_AUTO_ROLE_ROUTING=false
LLM_TEMPERATURE=0.7

# 固定全流程都使用 deepseek-chat
ANALYST_LLM_MODEL=deepseek-chat
GENERATOR_LLM_MODEL=deepseek-chat
AUDITOR_LLM_MODEL=deepseek-chat

# ============================================
# 其他可用的 LLM 配置
# ============================================

# === Kimi (Moonshot) ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_kimi_api_key_here
# LLM_BASE_URL=https://api.moonshot.cn/v1
# LLM_MODEL=kimi-k2.5
# LLM_TEMPERATURE=1
# ANALYST_LLM_MODEL=kimi-k2.5
# GENERATOR_LLM_MODEL=kimi-k2.5
# AUDITOR_LLM_MODEL=kimi-k2.5

# === 智谱 GLM-4 ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_zhipu_api_key_here
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-flash  # 或 glm-4-plus
# LLM_TEMPERATURE=0.7
# ANALYST_LLM_MODEL=glm-4-flash
# GENERATOR_LLM_MODEL=glm-4-flash
# AUDITOR_LLM_MODEL=glm-4-flash

# === 通义千问 ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_qwen_api_key_here
# LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL=qwen-plus  # 或 qwen-turbo
# LLM_TEMPERATURE=0.7
# ANALYST_LLM_MODEL=qwen-plus
# GENERATOR_LLM_MODEL=qwen-plus
# AUDITOR_LLM_MODEL=qwen-plus

# === Google Gemini ===
# LLM_PROVIDER=gemini
# LLM_API_KEY=your_gemini_api_key_here
# LLM_MODEL=gemini-1.5-pro
# LLM_PROXY=http://127.0.0.1:7890  # 如需代理

# === OpenAI ===
# LLM_PROVIDER=openai
# LLM_API_KEY=your_openai_api_key_here
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o
# LLM_TEMPERATURE=0.7

# ============================================
# Embedding 模型配置
# ============================================
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# ============================================
# ChromaDB 配置
# ============================================
CHROMA_PERSIST_DIR=./data/chroma_db
CHROMA_COLLECTION_NAME=medical_knowledge

# ============================================
# 日志配置
# ============================================
LOG_LEVEL=INFO  # DEBUG, INFO, WARNING, ERROR

# ============================================
# 生成配置
# ============================================
NUM_EXAM_VERSIONS=3  # 生成几套翻新卷
MAX_RETRY_ATTEMPTS=5  # 每道题最大重试次数（已优化）

# ============================================
# RAG 配置
# ============================================
RAG_CHUNK_SIZE=500
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=5

# 知识点匹配权重 (0-1)
# 越高越侧重知识点匹配，越低越侧重题目内容匹配
# 建议值：0.7 表示 70% 权重给知识点，30% 给题目内容
RAG_KNOWLEDGE_WEIGHT=0.7

# ============================================
# 审核配置
# ============================================
# 防抄袭阈值 (连续相同字符数上限)
PLAGIARISM_THRESHOLD=15  # 提高到15使审核更宽松，降低拒绝率

# ============================================
# 模型推荐
# ============================================
#
# 1. DeepSeek (推荐) ⭐⭐⭐⭐⭐
#    - 价格: ¥1-2/百万tokens
#    - 中文能力: 优秀
#    - 适合: 预算有限、大量生成
#
# 2. Kimi K2.5 ⭐⭐⭐⭐
#    - 价格: ¥12/百万tokens
#    - 中文能力: 优秀
#    - 适合: 追求质量、预算充足
#
# 3. GLM-4-Flash ⭐⭐⭐⭐
#    - 价格: ¥1/百万tokens
#    - 中文能力: 良好
#    - 适合: 性价比、速度优先
#
# 4. GLM-4-Plus ⭐⭐⭐⭐
#    - 价格: ¥50/百万tokens
#    - 中文能力: 优秀
#    - 适合: 追求最高质量
#
